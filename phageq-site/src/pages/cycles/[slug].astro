---
import Base from "../../layouts/Base.astro";
import fs from "fs";
import path from "path";
import { codeToHtml } from "shiki";

export async function getStaticPaths() {
  const blogDir = path.resolve("../agent/blog-posts");
  try {
    const files = fs.readdirSync(blogDir).filter((f) => f.endsWith(".md"));
    return files.map((f) => ({ params: { slug: f.replace(".md", "") } }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;
const blogDir = path.resolve("../agent/blog-posts");

let content = "";
let cycleNum = 0;
let date = "";
let notFound = false;

try {
  const filePath = path.join(blogDir, `${slug}.md`);
  const raw = fs.readFileSync(filePath, "utf8");

  const cycleMatch = slug?.match(/cycle-(\d+)/);
  cycleNum = cycleMatch ? parseInt(cycleMatch[1]) : 0;

  const dateMatch = raw.match(/date:\s*(.+)/);
  date = dateMatch
    ? new Date(dateMatch[1].trim()).toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        year: "numeric",
      })
    : "";

  content = raw.replace(/^---[\s\S]*?---\n/, "").trim();
} catch {
  notFound = true;
}

let prevNum: number | null = null;
let nextNum: number | null = null;

try {
  const files = fs
    .readdirSync(blogDir)
    .filter((f) => f.endsWith(".md"))
    .map((f) => parseInt(f.match(/cycle-(\d+)/)?.[1] ?? "0"))
    .sort((a, b) => a - b);

  const idx = files.indexOf(cycleNum);
  if (idx > 0) prevNum = files[idx - 1];
  if (idx < files.length - 1) nextNum = files[idx + 1];
} catch {}

// Custom phageq theme — matches site palette exactly
const phageqTheme = {
  name: "phageq",
  type: "dark" as const,
  colors: {
    "editor.background": "#0D1F1A",
    "editor.foreground": "#9ECFBE",
  },
  tokenColors: [
    {
      scope: ["comment", "punctuation.definition.comment"],
      settings: { foreground: "#2E5A46" },
    },
    {
      scope: ["keyword", "storage.type", "storage.modifier"],
      settings: { foreground: "#00C896" },
    },
    { scope: ["keyword.operator"], settings: { foreground: "#4DDFB2" } },
    {
      scope: ["entity.name.type", "entity.name.class", "support.type"],
      settings: { foreground: "#7FFFD4" },
    },
    {
      scope: ["entity.name.function", "support.function", "meta.function-call"],
      settings: { foreground: "#00E5A8" },
    },
    {
      scope: ["variable", "variable.other"],
      settings: { foreground: "#9ECFBE" },
    },
    { scope: ["variable.parameter"], settings: { foreground: "#B2DFCE" } },
    { scope: ["string", "string.quoted"], settings: { foreground: "#4DDFB2" } },
    {
      scope: ["constant.numeric", "constant.language"],
      settings: { foreground: "#7FFFD4" },
    },
    {
      scope: ["constant.language.boolean"],
      settings: { foreground: "#00C896" },
    },
    {
      scope: ["punctuation", "meta.brace"],
      settings: { foreground: "#3A6B55" },
    },
    {
      scope: ["meta.type.annotation", "meta.type.parameters"],
      settings: { foreground: "#00A87A" },
    },
    { scope: ["support.type.primitive"], settings: { foreground: "#00C896" } },
    { scope: ["entity.name.tag"], settings: { foreground: "#00E5A8" } },
    {
      scope: ["import", "keyword.control.import"],
      settings: { foreground: "#00C896" },
    },
  ],
};

// Parses a benchmark delta line like:
// "throughput_small: 46228 → 63134 jobs/sec (+36.6%)"
// or "throughput_small: 46228 → measuring jobs/sec"
// Returns structured HTML for the benchmark delta table
function renderBenchmarkDelta(deltaText: string): string {
  // Extract all metric lines from the raw delta text block
  const lines = deltaText
    .split(
      /throughput_small:|throughput_large:|latency_sensitive:|concurrent_heavy:|memory_pressure:/,
    )
    .slice(1);

  const metricNames = [
    "throughput_small",
    "throughput_large",
    "latency_sensitive",
    "concurrent_heavy",
    "memory_pressure",
  ];

  const rows = lines.map((line, i) => {
    const name = metricNames[i] ?? `metric_${i}`;
    const clean = line.trim().replace(/\s+/g, " ");

    // Check for measuring (benchmarks not yet captured)
    if (
      clean.includes("[measuring]") ||
      clean.startsWith("measuring") ||
      clean.match(/→\s*measuring/)
    ) {
      return `
        <div class="bench-row">
          <span class="bench-name">${name}</span>
          <span class="bench-values">
            <span class="bench-before">${clean.split("→")[0]?.trim() ?? "—"}</span>
            <span class="bench-arrow">→</span>
            <span class="bench-measuring">measuring</span>
          </span>
          <span class="bench-delta bench-delta--measuring">pending</span>
        </div>`;
    }

    // Parse: "46228 → 63134 jobs/sec (+36.6%)"
    const arrowMatch = clean.match(/(\d[\d,]*)\s*→\s*(\d[\d,]*)/);
    const pctMatch = clean.match(/\(([+-][\d.]+%)\)/);

    if (!arrowMatch) {
      return `<div class="bench-row"><span class="bench-name">${name}</span><span class="bench-values bench-raw">${clean}</span></div>`;
    }

    const before = parseInt(arrowMatch[1].replace(/,/g, ""));
    const after = parseInt(arrowMatch[2].replace(/,/g, ""));
    const pct = pctMatch?.[1] ?? null;

    // Compute pct ourselves if not in text
    const computedPct =
      pct ??
      (before > 0
        ? `${(((after - before) / before) * 100).toFixed(1)}%`
        : null);
    const isPositive = after >= before;
    const deltaClass = isPositive
      ? "bench-delta--positive"
      : "bench-delta--negative";
    const sign = isPositive ? "+" : "";
    const displayPct = computedPct
      ? computedPct.startsWith("+") || computedPct.startsWith("-")
        ? computedPct
        : `${sign}${computedPct}`
      : null;

    return `
      <div class="bench-row">
        <span class="bench-name">${name}</span>
        <span class="bench-values">
          <span class="bench-before">${before.toLocaleString()}</span>
          <span class="bench-arrow">→</span>
          <span class="bench-after ${isPositive ? "bench-after--up" : "bench-after--down"}">${after.toLocaleString()}</span>
          <span class="bench-unit">jobs/sec</span>
        </span>
        ${displayPct ? `<span class="bench-delta ${deltaClass}">${displayPct}</span>` : ""}
      </div>`;
  });

  return `<div class="bench-table">${rows.join("")}</div>`;
}

// Parses a leaderboard line like:
// "throughput_small: phageq 54961 | p-queue 29214 | toad-scheduler 79947"
// or "throughput_small: phageq [measuring] | p-queue 31724 | toad-scheduler 95639"
function renderLeaderboard(leaderboardText: string): string {
  const metricNames = [
    "throughput_small",
    "throughput_large",
    "latency_sensitive",
    "concurrent_heavy",
    "memory_pressure",
  ];

  const rows: string[] = [];

  for (const metric of metricNames) {
    const regex = new RegExp(`${metric}:\\s*([^\\n]+)`, "i");
    const match = leaderboardText.match(regex);
    if (!match) continue;

    const parts = match[1].split("|").map((p) => p.trim());
    const libs = parts.map((part) => {
      // e.g. "phageq 54961" or "phageq [measuring]" or "p-queue 29214"
      const measuring =
        part.includes("[measuring]") || part.includes("measuring");
      const numMatch = part.match(/[\d,]+/);
      const nameMatch = part.match(/^([a-z\-]+)/i);
      const name = nameMatch?.[1] ?? part;
      const value = measuring
        ? null
        : numMatch
          ? parseInt(numMatch[0].replace(/,/g, ""))
          : null;
      return { name, value, measuring };
    });

    // Find winner (highest value among non-measuring)
    const values = libs
      .filter((l) => l.value !== null)
      .map((l) => l.value as number);
    const maxVal = values.length > 0 ? Math.max(...values) : null;

    const libCells = libs.map((lib) => {
      const isWinner = lib.value !== null && lib.value === maxVal;
      const isPhage = lib.name === "phageq";
      let cellClass = "lb-lib";
      if (isWinner) cellClass += " lb-lib--winner";
      if (isPhage) cellClass += " lb-lib--phage";

      const displayVal = lib.measuring
        ? `<span class="lb-measuring" title="Benchmarks run at end of cycle — check leaderboard for final numbers">—</span>`
        : `<span class="lb-value">${lib.value?.toLocaleString()}</span>`;

      return `<div class="${cellClass}">
        <span class="lb-name">${lib.name}</span>
        ${displayVal}
        ${isWinner && !lib.measuring ? '<span class="lb-crown">↑</span>' : ""}
      </div>`;
    });

    rows.push(`
      <div class="lb-row">
        <span class="lb-metric">${metric}</span>
        <div class="lb-libs">${libCells.join("")}</div>
      </div>`);
  }

  const hasMeasuring =
    leaderboardText.includes("[measuring]") ||
    leaderboardText.includes("measuring");

  return `
    <div class="lb-table">
      ${rows.join("")}
      ${hasMeasuring ? `<p class="lb-note">— scores update at end of cycle. Check the <a href="/leaderboard">leaderboard</a> for current numbers.</p>` : ""}
    </div>`;
}

// Pre-processes markdown to replace benchmark delta and leaderboard sections
// with styled HTML before the main renderMarkdown pass
function preprocessBenchmarks(md: string): string {
  // Replace **Benchmark delta:** block
  md = md.replace(
    /\*\*Benchmark delta:\*\*\s*([\s\S]*?)(?=\n\*\*|\n---|\n##|$)/,
    (_, deltaBlock) => {
      return `\n\nBENCH_DELTA_HTML\n${renderBenchmarkDelta(deltaBlock)}\nBENCH_DELTA_END\n\n`;
    },
  );

  // Replace **Leaderboard:** block
  md = md.replace(
    /\*\*Leaderboard:\*\*\s*([\s\S]*?)(?=\n\*\*|\n---|\n##|$)/,
    (_, lbBlock) => {
      return `\n\nLEADERBOARD_HTML\n${renderLeaderboard(lbBlock)}\nLEADERBOARD_END\n\n`;
    },
  );

  return md;
}

// Renders markdown to HTML, with Shiki syntax highlighting for fenced code blocks
async function renderMarkdown(md: string): Promise<string> {
  // Pre-process benchmark sections first
  md = preprocessBenchmarks(md);

  // Step 1: extract and highlight all fenced code blocks first
  const highlightedBlocks: string[] = [];
  const blockMatches = [...md.matchAll(/```(\w*)\n([\s\S]*?)```/g)];

  for (const match of blockMatches) {
    const lang = match[1] || "typescript";
    const code = match[2];
    try {
      const highlighted = await codeToHtml(code, { lang, theme: phageqTheme });
      highlightedBlocks.push(`<div class="code-block">${highlighted}</div>`);
    } catch {
      const escaped = code
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
      highlightedBlocks.push(
        `<div class="code-block"><pre><code>${escaped}</code></pre></div>`,
      );
    }
  }

  // Step 2: replace code blocks with numbered placeholders
  let blockIdx = 0;
  const withPlaceholders = md.replace(/```(\w*)\n([\s\S]*?)```/g, () => {
    return `\n\nCODE_BLOCK_PLACEHOLDER_${blockIdx++}\n\n`;
  });

  // Step 3: process the rest of the markdown
  blockIdx = 0;
  return withPlaceholders
    .replace(/^## (.+)$/gm, "<h2>$1</h2>")
    .replace(/^### (.+)$/gm, "<h3>$1</h3>")
    .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .split("\n\n")
    .map((p) => {
      const trimmed = p.trim();
      if (!trimmed) return "";
      // Swap placeholders back for highlighted blocks
      if (trimmed.startsWith("CODE_BLOCK_PLACEHOLDER_")) {
        const idx = parseInt(trimmed.replace("CODE_BLOCK_PLACEHOLDER_", ""));
        return highlightedBlocks[idx] ?? "";
      }
      // Pass pre-rendered benchmark/leaderboard HTML through directly
      if (
        trimmed.startsWith("BENCH_DELTA_HTML") ||
        trimmed.startsWith("LEADERBOARD_HTML")
      ) {
        // Extract the HTML between the markers
        const htmlContent = trimmed
          .replace(/^BENCH_DELTA_HTML\n/, "")
          .replace(/\nBENCH_DELTA_END$/, "")
          .replace(/^LEADERBOARD_HTML\n/, "")
          .replace(/\nLEADERBOARD_END$/, "");
        return htmlContent;
      }
      if (
        trimmed.startsWith("<h") ||
        trimmed.startsWith("<pre") ||
        trimmed.startsWith("<div") ||
        trimmed.startsWith("<p class=")
      )
        return trimmed;
      return `<p>${trimmed.replace(/\n/g, " ")}</p>`;
    })
    .join("\n");
}

const html = notFound ? "" : await renderMarkdown(content);
---

<Base title={`Cycle ${cycleNum}`}>
  <div class="page">
    <div class="container">
      {
        notFound ? (
          <div class="not-found fade-up">
            <p>Cycle not found.</p>
            <a href="/cycles">← all cycles</a>
          </div>
        ) : (
          <>
            <div class="post-header fade-up">
              <a href="/cycles" class="back">
                ← all cycles
              </a>
              <div class="post-meta">
                <span class="tag tag--green">cycle {cycleNum}</span>
                <span class="post-date">{date}</span>
              </div>
              <h1 class="post-title">
                cycle {String(cycleNum).padStart(3, "0")}
              </h1>
            </div>

            <div class="post-body fade-up-1" set:html={html} />

            <div class="post-nav fade-up-2">
              {prevNum !== null ? (
                <a
                  href={`/cycles/cycle-${String(prevNum).padStart(3, "0")}`}
                  class="post-nav__link post-nav__link--prev"
                >
                  <span class="post-nav__dir">← previous</span>
                  <span class="post-nav__label">cycle {prevNum}</span>
                </a>
              ) : (
                <div />
              )}

              {nextNum !== null ? (
                <a
                  href={`/cycles/cycle-${String(nextNum).padStart(3, "0")}`}
                  class="post-nav__link post-nav__link--next"
                >
                  <span class="post-nav__dir">next →</span>
                  <span class="post-nav__label">cycle {nextNum}</span>
                </a>
              ) : (
                <div />
              )}
            </div>
          </>
        )
      }
    </div>
  </div>
</Base>

<style>
  .page {
    padding: 60px 0 80px;
  }

  .back {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    margin-bottom: 24px;
    transition: color 0.15s;
  }
  .back:hover {
    color: var(--green);
  }

  .post-header {
    margin-bottom: 40px;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .post-date {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--text);
    line-height: 1;
  }

  .post-body {
    max-width: 680px;
    font-size: 0.88rem;
    line-height: 1.85;
    color: var(--text-muted);
    min-width: 0;
  }

  .post-body :global(h2) {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 36px 0 14px;
    font-weight: 400;
  }
  .post-body :global(h3) {
    font-size: 0.88rem;
    color: var(--text);
    margin: 24px 0 10px;
    font-weight: 400;
    letter-spacing: 0.04em;
  }
  .post-body :global(p) {
    margin-bottom: 16px;
    color: var(--text-muted);
  }
  .post-body :global(strong) {
    color: var(--text);
    font-weight: 500;
  }

  /* Inline code */
  .post-body :global(code) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 0.82em;
    color: var(--green-light);
    font-family: "DM Mono", "Fira Code", monospace;
  }

  /* Shiki highlighted code blocks */
  .post-body :global(.code-block) {
    margin: 24px 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 100%;
  }

  .post-body :global(.code-block pre) {
    margin: 0 !important;
    padding: 20px !important;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.6;
  }

  /* Override inline code styles inside highlighted blocks */
  .post-body :global(.code-block code) {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-size: inherit !important;
    color: inherit !important;
    font-family: "DM Mono", "Fira Code", monospace;
  }

  /* ── Benchmark Delta Table ── */
  .post-body :global(.bench-table) {
    margin: 20px 0 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
  }

  .post-body :global(.bench-row) {
    display: grid;
    grid-template-columns: 160px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 0.78rem;
  }

  .post-body :global(.bench-row:last-child) {
    border-bottom: none;
  }

  .post-body :global(.bench-name) {
    color: var(--text-muted);
    letter-spacing: 0.04em;
    font-size: 0.72rem;
  }

  .post-body :global(.bench-values) {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-body :global(.bench-before) {
    color: var(--text-dim);
  }

  .post-body :global(.bench-arrow) {
    color: var(--text-dim);
    font-size: 0.7rem;
  }

  .post-body :global(.bench-after--up) {
    color: var(--green);
    font-weight: 500;
  }

  .post-body :global(.bench-after--down) {
    color: var(--red);
    font-weight: 500;
  }

  .post-body :global(.bench-unit) {
    color: var(--text-dim);
    font-size: 0.68rem;
  }

  .post-body :global(.bench-measuring) {
    color: var(--text-dim);
    font-style: italic;
  }

  .post-body :global(.bench-delta) {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 3px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .post-body :global(.bench-delta--positive) {
    color: var(--green);
    background: rgba(0, 200, 150, 0.1);
    border: 1px solid rgba(0, 200, 150, 0.2);
  }

  .post-body :global(.bench-delta--negative) {
    color: var(--red);
    background: rgba(255, 92, 92, 0.1);
    border: 1px solid rgba(255, 92, 92, 0.2);
  }

  .post-body :global(.bench-delta--measuring) {
    color: var(--text-dim);
    background: transparent;
    border: 1px solid var(--border);
  }

  .post-body :global(.bench-raw) {
    color: var(--text-dim);
    font-size: 0.72rem;
  }

  /* ── Leaderboard Table ── */
  .post-body :global(.lb-table) {
    margin: 20px 0 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
  }

  .post-body :global(.lb-row) {
    display: grid;
    grid-template-columns: 160px 1fr;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 0.78rem;
  }

  .post-body :global(.lb-row:last-of-type) {
    border-bottom: none;
  }

  .post-body :global(.lb-metric) {
    color: var(--text-muted);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }

  .post-body :global(.lb-libs) {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-body :global(.lb-lib) {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .post-body :global(.lb-lib--phage) {
    border-color: rgba(0, 200, 150, 0.25);
  }

  .post-body :global(.lb-lib--winner) {
    background: rgba(0, 200, 150, 0.08);
    border-color: rgba(0, 200, 150, 0.35);
  }

  .post-body :global(.lb-name) {
    color: var(--text-dim);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  .post-body :global(.lb-lib--phage .lb-name) {
    color: var(--green);
  }

  .post-body :global(.lb-value) {
    color: var(--text);
    font-weight: 500;
    font-size: 0.78rem;
  }

  .post-body :global(.lb-lib--winner .lb-value) {
    color: var(--green-light);
  }

  .post-body :global(.lb-crown) {
    color: var(--green);
    font-size: 0.68rem;
  }

  .post-body :global(.lb-measuring) {
    color: var(--text-dim);
    font-size: 0.72rem;
  }

  .post-body :global(.lb-note) {
    font-size: 0.7rem !important;
    color: var(--text-dim) !important;
    padding: 10px 16px;
    margin: 0 !important;
    border-top: 1px solid var(--border);
    font-style: italic;
  }

  .post-body :global(.lb-note a) {
    color: var(--green);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 60px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .post-nav__link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--text);
  }
  .post-nav__link--next {
    text-align: right;
  }
  .post-nav__dir {
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .post-nav__label {
    font-size: 0.85rem;
    color: var(--green);
  }

  .not-found {
    padding: 60px 0;
    color: var(--text-muted);
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
</style>

<style is:global>
  @media (max-width: 640px) {
    .post-title {
      font-size: 2rem;
    }
    .post-body {
      font-size: 0.84rem;
    }
    .post-nav {
      flex-direction: column;
      gap: 20px;
    }
    .post-nav__link--next {
      text-align: left;
    }
