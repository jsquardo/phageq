{
  "name": "phageq",
  "version": "0.1.0",
  "description": "A task queue that rewrites itself.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "bench": "tsx benchmarks/run.ts",
    "bench:competitors": "tsx benchmarks/competitors.ts",
    "bench:all": "npm run bench && npm run bench:competitors",
    "agent": "tsx agent/loop.ts",
    "agent:watch": "tsx agent/loop.ts --watch"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "queue",
    "task-queue",
    "concurrency",
    "jobs"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.37",
    "bullmq": "^5.12.0",
    "jest": "^29.7.0",
    "p-queue": "^8.0.1",
    "toad-scheduler": "^3.0.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
